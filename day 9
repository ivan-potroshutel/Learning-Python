    name = input("what is your name? ")
    bill = int(input("what is your bill? "))
    retask = input("are there any other bidders? Type 'yes or 'no'.\n").lower()
    bids[name] = bill
    if retask == "no":
        continue_bidding = False
        find_highest_bidder(bids)
