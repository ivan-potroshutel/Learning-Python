def find_highest_bidder(bid_record):
    highest_bidder = 0
    winner = ""
    for bider in bid_record:
        bid_amount = bid_record[bider]
        if bid_amount > highest_bidder:
            highest_bidder = bid_amount
            winner = bider
    print(f"The winner is {winner} with a bid of ${highest_bidder}")

